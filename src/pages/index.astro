  </head>

  <body>
    <Header />
    <main class="m-auto grid max-w-5xl justify-items-center px-8 py-12">
      <section>
        <ul class="m-0 flex flex-wrap content-between gap-8 p-0">
          {
            posts.map((post) => (
              <li class="w-[calc(50%-1em)] first:mb-1 first:w-full first:text-center">
                <a class="group/link" href={`/${post.id}/`}>
                  {post.data.heroImage && (
                    <Image
                      class="mb-2 rounded-lg group-hover/link:shadow-lg first:w-full"
                      width={720}
                      height={360}
                      src={post.data.heroImage}
                      alt=""
                    />
                  )}
                  <h4 class="group-hover/link:text-accent-foreground text-xl font-bold lg:text-4xl">
                    {post.data.title}
                  </h4>
                  <p class="text-muted-foreground group-hover/link:text-accent-foreground text-xs lg:text-base">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
